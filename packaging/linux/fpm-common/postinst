# packaging/linux/fpm-common/postinst

set -e

if [ "$1" = "configure" ]; then
    echo "----------------------------------------------------------------------"
    echo "ECLI has been successfully installed."
    echo
    echo "On the first run, user configuration files will be automatically"
    echo "created in the following directory:"
    echo "  ~/.config/ecli/"
    echo
    echo "Please edit the '.env' file in that directory to add your API keys"
    echo "for AI features."
    echo "----------------------------------------------------------------------"
fi

exit 0
