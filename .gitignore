# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Development logs and generated test evidence
# Repository-level development log invariant.
# Generated development logs, dry-run reports, smoke outputs,
# test evidence, and agent debug artifacts must live only under logs/.
/logs/**
!/logs/.gitkeep
!/logs/README.md

